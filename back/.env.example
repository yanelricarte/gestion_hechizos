# Copiá este archivo como .env y completá los valores.

# Cadena de conexión a MongoDB.
MONGODB_URI=mongodb://localhost:27017/gestion_hechizos

# Secreto para firmar la cookie de sesión (poné algo largo y aleatorio).
SESSION_SECRET=cambiame-por-un-secreto-largo

# Origen del frontend permitido por CORS.
FRONTEND_URL=http://localhost:10000

# Puerto del servidor.
PORT=5000
